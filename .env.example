# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=4000

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_GRAPHQL_URL=http://localhost:4000/graphql

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rickmorty

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Cache ────────────────────────────────────────────────────────────────────
# TTL in seconds for cached queries (default: 5 minutes)
CACHE_TTL=300

# ─── External API ─────────────────────────────────────────────────────────────
# Rick and Morty public API (used by the seeding cron job)
RICKMORTY_API_URL=https://rickandmortyapi.com/api
