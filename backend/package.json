{
  "name": "rick-and-morty-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "TS_NODE_TRANSPILE_ONLY=true node --require ts-node/register $(npm root)/.bin/sequelize-cli db:migrate",
    "db:migrate:undo": "TS_NODE_TRANSPILE_ONLY=true node --require ts-node/register $(npm root)/.bin/sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "TS_NODE_TRANSPILE_ONLY=true node --require ts-node/register $(npm root)/.bin/sequelize-cli db:migrate:undo:all",
    "db:seed": "TS_NODE_TRANSPILE_ONLY=true node --require ts-node/register $(npm root)/.bin/sequelize-cli db:seed:all"
  },
  "dependencies": {
    "@apollo/server": "^4.10.4",
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/merge": "^8.4.2",
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "graphql": "^16.8.1",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "jest": "^29.7.0",
    "sequelize-cli": "^6.6.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
